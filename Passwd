c1 = 0
c2 = 0
c3 = 0
c4 = 0

passwd = input("Введите ваш пароль ")

if len(passwd) >= 8:
    c1 = 1

for s in passwd:

    if s.isdigit() == True:
      c2 = 1
      
    if s.islower() == True:
      c3 = 1
      
    if s.isupper() == True:
      c4 = 1
 
if c1 + c2 + c3 + c4 == 4:
    print('Надёжный пароль')
else:
    print('фигня')
